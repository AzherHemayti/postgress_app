datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String?
  password String
  role     String @default("user")
  tasks    Task[]
}

model Task {
  id        Int    @id @default(autoincrement())
  title     String
  completed Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])
}